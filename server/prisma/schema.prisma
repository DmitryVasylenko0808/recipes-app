// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Author {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  firstname    String
  secondname   String
  bio          String?
  avatar       String?
  createdAt    DateTime @default(now()) @map("created_at")

  recipes         Recipe[]
  favoriteRecipes FavoriteRecipe[]
  comments        Comment[]
  ratings         Rating[]

  @@map("authors")
}

model Recipe {
  id           String     @id @default(uuid())
  title        String
  categoryId   String     @map("category_id")
  category     Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  description  String
  previewImage String     @map("preview_image")
  content      String
  cookingTime  Int        @map("cooking_time")
  difficulty   Difficulty
  viewsCount   Int        @default(0) @map("views_count")
  ratingsCount Int        @default(0) @map("ratings_count")
  ratingsSum   Int        @default(0) @map("ratings_sum")
  ratingsAvg   Float      @default(0) @map("ratings_avg")
  createdAt    DateTime   @default(now()) @map("created_at")

  authorId String @map("author_id")
  author   Author @relation(fields: [authorId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  recipeTags        RecipeTag[]
  recipeIngredients RecipeIngredient[]

  favoriteEntries FavoriteRecipe[]
  comments        Comment[]
  ratings         Rating[]

  @@map("recipes")
}

model Rating {
  id       String @id @default(uuid())
  userId   String @map("user_id")
  user     Author @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  recipeId String @map("recipe_id")
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  value    Int

  @@unique([userId, recipeId])
  @@map("ratings")
}

model FavoriteRecipe {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  user        Author   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  recipeId    String   @map("recipe_id")
  recipe      Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  favoritedAt DateTime @default(now()) @map("favorited_at")

  @@unique([userId, recipeId])
  @@map("favorite_recipes")
}

model Comment {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      Author   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  recipeId  String   @map("recipe_id")
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("comments")
}

model Category {
  id      String   @id @default(uuid())
  name    String   @unique
  recipes Recipe[]

  @@map("categories")
}

model RecipeTag {
  recipeId String @map("recipe_id")
  tagId    String @map("tag_id")

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@id([recipeId, tagId])
  @@map("recipe_tags")
}

model Tag {
  id         String      @id @default(uuid())
  name       String      @unique
  recipeTags RecipeTag[]

  @@map("tags")
}

model RecipeIngredient {
  id     String @id @default(uuid())
  amount Int
  unit   String

  recipeId String @map("recipe_id")
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  ingredientId String     @map("ingredient_id")
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("recipe_ingredients")
}

model Ingredient {
  id   String @id @default(uuid())
  name String @unique

  recipeIngredients RecipeIngredient[]

  @@map("ingredients")
}

enum Difficulty {
  easy
  medium
  hard
}
