// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Author {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  firstname    String
  secondname   String
  bio          String?
  avatar       String?
  createdAt    DateTime @default(now()) @map("created_at")

  recipes         Recipe[]
  favoriteRecipes FavoriteRecipe[]
  comments        Comment[]
  ratings         Rating[]
  commentLikes    CommentLike[]

  @@map("authors")
}

model Recipe {
  id String @id @default(uuid())

  recipeVersions RecipeVersion[] @relation("RecipeVersions")

  currentVersionId String?        @unique @map("current_version_id")
  currentVersion   RecipeVersion? @relation("CurrentRecipeVersion", fields: [currentVersionId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  viewsCount   Int      @default(0) @map("views_count")
  ratingsCount Int      @default(0) @map("ratings_count")
  ratingsSum   Int      @default(0) @map("ratings_sum")
  ratingsAvg   Float    @default(0) @map("ratings_avg")
  createdAt    DateTime @default(now()) @map("created_at")

  authorId String @map("author_id")
  author   Author @relation(fields: [authorId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  favoriteEntries FavoriteRecipe[]
  comments        Comment[]
  ratings         Rating[]

  @@map("recipes")
}

model RecipeVersion {
  id String @id @default(uuid())

  recipeId        String  @map("recipe_id")
  recipe          Recipe  @relation("RecipeVersions", fields: [recipeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  currentRecipeOf Recipe? @relation("CurrentRecipeVersion")
  version         Int

  title             String
  description       String
  previewImage      String             @map("preview_image")
  cookingTime       Int                @map("cooking_time")
  difficulty        Difficulty
  categoryId        String             @map("category_id")
  category          Category           @relation(fields: [categoryId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  recipeSteps       RecipeStep[]
  recipeTags        RecipeTag[]
  recipeIngredients RecipeIngredient[]

  changeDescription String?  @map("change_description")
  createdAt         DateTime @default(now()) @map("created_at")

  @@unique([recipeId, version])
  @@map("recipe_versions")
}

model Category {
  id             String          @id @default(uuid())
  name           String          @unique
  recipeVersions RecipeVersion[]

  @@map("categories")
}

model RecipeStep {
  id              String        @id @default(uuid())
  content         String
  recipeVersionId String        @map("recipe_version_id")
  recipeVersion   RecipeVersion @relation(fields: [recipeVersionId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("recipe_steps")
}

model RecipeTag {
  recipeVersionId String        @map("recipe_version_id")
  recipeVersion   RecipeVersion @relation(fields: [recipeVersionId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  tagId           String        @map("tag_id")
  tag             Tag           @relation(fields: [tagId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@id([recipeVersionId, tagId])
  @@map("recipe_tags")
}

model Tag {
  id         String      @id @default(uuid())
  name       String      @unique
  recipeTags RecipeTag[]

  @@map("tags")
}

model RecipeIngredient {
  id              String        @id @default(uuid())
  amount          Int
  unit            String
  recipeVersionId String        @map("recipe_version_id")
  recipeVersion   RecipeVersion @relation(fields: [recipeVersionId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  ingredientId    String        @map("ingredient_id")
  ingredient      Ingredient    @relation(fields: [ingredientId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("recipe_ingredients")
}

model Ingredient {
  id   String @id @default(uuid())
  name String @unique

  recipeIngredients RecipeIngredient[]

  @@map("ingredients")
}

model Rating {
  id       String @id @default(uuid())
  userId   String @map("user_id")
  user     Author @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  recipeId String @map("recipe_id")
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  value    Int

  @@unique([userId, recipeId])
  @@map("ratings")
}

model FavoriteRecipe {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  user        Author   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  recipeId    String   @map("recipe_id")
  recipe      Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  favoritedAt DateTime @default(now()) @map("favorited_at")

  @@unique([userId, recipeId])
  @@map("favorite_recipes")
}

model Comment {
  id         String        @id @default(uuid())
  userId     String        @map("user_id")
  user       Author        @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  recipeId   String        @map("recipe_id")
  recipe     Recipe        @relation(fields: [recipeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  content    String
  likesCount Int           @default(0) @map("likes_count")
  likes      CommentLike[]
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  @@map("comments")
}

model CommentLike {
  userId    String  @map("user_id")
  user      Author  @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  commentId String  @map("comment_id")
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([userId, commentId])
  @@map("comment_likes")
}

enum Difficulty {
  easy
  medium
  hard
}
